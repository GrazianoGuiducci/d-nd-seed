#!/bin/bash
# ============================================================================
# MODUS COPY — Observer positioning in content production
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# Fires on PostToolUse (Edit, Write). When the system writes content,
# this hook reminds: position the observer before the content.
#
# Not a validator. Not a checker. The rule operating.
# The kernel says what. This hook does.
# ============================================================================

read -t 1 INPUT_LINE 2>/dev/null || INPUT_LINE=""

# Parse tool name and file path
eval "$(echo "$INPUT_LINE" | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    tn = d.get('tool_name', '')
    ti = d.get('tool_input', {})
    print(f'TOOL_NAME=\"{tn}\"')
    if tn in ('Edit', 'Write'):
        fp = ti.get('file_path', '')
        ns = ti.get('new_string', ti.get('content', ''))[:500]
        print(f'FILE_PATH=\"{fp}\"')
        print(f'CONTENT_PREVIEW=\"{ns[:200]}\"')
except:
    print('TOOL_NAME=\"\"')
" 2>/dev/null)"

# Only fire on Edit or Write
[ "$TOOL_NAME" != "Edit" ] && [ "$TOOL_NAME" != "Write" ] && exit 0

# Only fire on content files (not code, not config)
case "$FILE_PATH" in
    *.md|*.txt|*.html|*.tsx|*.jsx)
        # Check if the content is copy/text (not pure code)
        ;;
    *)
        exit 0
        ;;
esac

# Rate limit: max 1 reminder per 3 minutes
LAST_FILE="/tmp/.modus_copy_last_{{NODE_ID}}"
NOW=$(date +%s)
if [ -f "$LAST_FILE" ]; then
    LAST=$(cat "$LAST_FILE")
    [ $((NOW - LAST)) -lt 180 ] && exit 0
fi

# Detect content production patterns (copy, descriptions, explanations)
# Skip pure code modifications
CONTENT_PATTERNS="description|title|label|copy|text|intro|subtitle|placeholder|hero|heading"
if echo "$CONTENT_PREVIEW" | grep -qiE "$CONTENT_PATTERNS"; then
    echo "$NOW" > "$LAST_FILE"
    echo ">>> MODUS COPY: content detected in $FILE_PATH"
    echo ">>>   Positioning → Content → Result"
    echo ">>>   • When/where/in relation to what → what happens → what emerges"
    echo ">>>   • Inclusive (we/our, noi/facciamo) — never you/tu"
    echo ">>>   • Never describe the tool — say what emerges"
    echo ">>>   • Never command — accompany"
fi

exit 0

## Eval
## Trigger Tests
# Edit a .md file with "description" → fires modus reminder
# Edit a .js file with pure code → does NOT fire
# Two edits within 3 minutes → fires only once
## Fidelity Tests
# Always exits 0
# Rate limited to 1 per 3 minutes
