#!/bin/bash
# ============================================================================
# CASCADE CHECK — Post-action implication detector
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# Fires on PostToolUse (Edit, Write, Bash). Detects changes that affect
# other parts of the system and prints reminders.
#
# Principle: if what you do stops where you do it, there's no cascade
# and the system discharges on the source.
#
# This template is the base. Each node adapts to its own context by
# uncommenting optional sections or adding project-specific rules.
# ============================================================================

read -t 1 INPUT_LINE 2>/dev/null || INPUT_LINE=""

# Parse tool name, input, and result
eval "$(echo "$INPUT_LINE" | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    tn = d.get('tool_name', '')
    ti = d.get('tool_input', {})
    tr = d.get('tool_result', {})
    print(f'TOOL_NAME=\"{tn}\"')
    if tn in ('Edit', 'Write'):
        print(f'FILE_PATH=\"{ti.get(\"file_path\", \"\")}\"')
    elif tn == 'Bash':
        cmd = ti.get('command', '').replace('\"', '\\\\\"')
        stdout = tr.get('stdout', '').replace('\"', '\\\\\"')[:500]
        print(f'COMMAND=\"{cmd}\"')
        print(f'STDOUT=\"{stdout}\"')
except:
    print('TOOL_NAME=\"\"')
" 2>/dev/null)"

[ -z "$TOOL_NAME" ] && exit 0

# Rate limit: max 1 cascade alert per 2 minutes
LAST_FILE="/tmp/.cascade_check_last_{{NODE_ID}}"
NOW=$(date +%s)
if [ -f "$LAST_FILE" ]; then
    LAST=$(cat "$LAST_FILE")
    [ $((NOW - LAST)) -lt 120 ] && exit 0
fi

# ============================================================================
# SAFETY ALERTS — dangerous operations that need a pause
# ============================================================================

if [ "$TOOL_NAME" = "Bash" ]; then
    # Blind conflict resolution — never checkout --theirs/--ours without reading
    if echo "$COMMAND" | grep -qE "checkout --(theirs|ours)"; then
        echo ">>> STOP: checkout --theirs/--ours discards the other node's work."
        echo ">>> RULE: during rebase/merge, READ the conflict. Never resolve blindly."
        echo ">>> Use 'git diff' to understand both sides, then merge manually."
    fi
    # Rebase skip — discards a commit
    if echo "$COMMAND" | grep -qE "rebase --skip"; then
        echo ">>> STOP: rebase --skip DISCARDS a commit. Are you sure?"
    fi
fi

# ============================================================================
# DETECT WHAT CHANGED
# ============================================================================

CHANGED=""

case "$TOOL_NAME" in
    Edit|Write)
        CHANGED="$FILE_PATH"
        ;;
    Bash)
        # Only check git commits for file-level cascade
        echo "$COMMAND" | grep -q "git commit" || {
            # Check for content publish or git pull (non-commit triggers)
            # Uncomment the relevant section below if needed
            exit 0
        }
        CWD=$(pwd)
        CHANGED=$(git -C "$CWD" diff --name-only HEAD~1 HEAD 2>/dev/null | head -10 | tr '\n' ' ')
        ;;
    *)
        exit 0
        ;;
esac

[ -z "$CHANGED" ] && exit 0

# ============================================================================
# UNIVERSAL CASCADE RULES — apply to any project
# ============================================================================

FOUND=""
check() { echo "$CHANGED" | grep -qE "$1" && FOUND="${FOUND}>>> $2
"; }

# Identity and configuration
check "CLAUDE\.md$"       "CLAUDE.md modified: verify all nodes have consistent rules"
check "settings\.json"    "Settings modified: check if other nodes need the same change"
check "\.claude/"         "Claude config modified: transferable to seed? Other nodes need it?"

# Documentation and knowledge
check "^docs/"            "Docs modified: check if site or seed exposes updated knowledge"
check "README"            "README modified: does the seed or public repo need updating?"

# Infrastructure
check "^adapters/"        "API adapter modified: check if API docs and clients are aligned"
check "^services/"        "Service modified: deploy needed? Check downstream consumers"
check "^templates/"       "Template modified: downstream nodes may need hook regeneration"
check "^tools/"           "Tools modified: check if templates and docs reflect the new pattern"

# Content and SEO
check "\.html$"           "HTML modified: verify AI metatags (GEO) and internal links"
check "llms\.txt$"        "llms.txt modified: verify site navigation map is current"
check "sitemap"           "Sitemap modified: verify all published pages are included"

# Shared state
check "PROJECT_MEMORY"    "System state updated: other nodes will see this on next poll"
check "COWORK"            "Communication channel updated: verify the target node received it"

if [ -n "$FOUND" ]; then
    echo "$NOW" > "$LAST_FILE"
    echo ">>> CASCADE CHECK [{{NODE_ID}}]: implications detected"
    echo "$FOUND"
    echo ">>> Evaluate: does another node, the site, or the seed need to know?"
fi

