#!/bin/bash
# ============================================================================
# CASCADE CHECK — Post-commit implication detector
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# Fires on PostToolUse (Bash). After a git commit, checks if changed files
# have implications on other parts of the system and sends triggers.
#
# Principle: if what you do stops where you do it, there's no cascade
# and the system discharges on the source.
# ============================================================================

read -t 1 INPUT_LINE 2>/dev/null || INPUT_LINE=""

# Only trigger on Bash calls
TOOL_NAME=$(echo "$INPUT_LINE" | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print(d.get('tool_name', ''))
except:
    print('')
" 2>/dev/null)

[ "$TOOL_NAME" != "Bash" ] && exit 0

# Check if the bash command was a git commit
COMMAND=$(echo "$INPUT_LINE" | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print(d.get('tool_input', {}).get('command', ''))
except:
    print('')
" 2>/dev/null)

echo "$COMMAND" | grep -q "git commit" || exit 0

# Rate limit: max 1 cascade check per 5 minutes
LAST_CHECK_FILE="/tmp/.cascade_check_last_{{NODE_ID}}"
if [ -f "$LAST_CHECK_FILE" ]; then
    LAST=$(cat "$LAST_CHECK_FILE")
    NOW=$(date +%s)
    [ $((NOW - LAST)) -lt 300 ] && exit 0
fi
date +%s > "$LAST_CHECK_FILE"

# Detect repo name from git root
CWD=$(pwd)
REPO_NAME=$(basename "$(git -C "$CWD" rev-parse --show-toplevel 2>/dev/null)" 2>/dev/null)
[ -z "$REPO_NAME" ] && exit 0

# Get changed files from last commit
CHANGED=$(git -C "$CWD" diff --name-only HEAD~1 HEAD 2>/dev/null)
[ -z "$CHANGED" ] && exit 0

# Universal implication rules
# These patterns apply to any project. Add project-specific rules below.
check() { echo "$CHANGED" | grep -q "$1" && FOUND="${FOUND}>>> $2
"; }
FOUND=""

# Structure changes -> may affect downstream consumers
check "^seed/"       "seed/ modified: check if public seed repo needs update"
check "^tools/"      "tools/ modified: check if templates reflect the new pattern"
check "^docs/"       "docs/ modified: check if site exposes updated knowledge"
check "\.html$"      "HTML modified: verify AI metatags (GEO) and internal links"
check "^adapters/"   "adapters/ modified: check if API docs are aligned"
check "^templates/"  "templates/ modified: downstream nodes may need hook update"
check "CLAUDE\.md$"  "CLAUDE.md modified: verify all nodes have consistent rules"
check "llms\.txt$"   "llms.txt modified: verify site navigation map is current"

if [ -n "$FOUND" ]; then
    echo ">>> CASCADE CHECK [$REPO_NAME]: implications detected"
    echo "$FOUND"
    echo ">>> Evaluate whether to send triggers to connected nodes."
fi

