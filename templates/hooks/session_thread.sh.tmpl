#!/bin/bash
# ============================================================================
# SESSION THREAD — Track the thread across compactions
# ============================================================================
# PostToolUse hook: records recent actions + current task in a file.
# The file survives compaction and gets re-injected by post_compact.
# This solves the "re-orientation tax" after every compaction.
#
# Node: {{NODE_ID}}
# Generated by d-nd-seed installer
# ============================================================================

THREAD_FILE="{{PROJECT_DIR}}/.claude/hooks/session_thread.md"
MAX_ACTIONS=10

# Read input JSON from hook
read -t 2 INPUT_LINE 2>/dev/null || INPUT_LINE=""

# Extract tool name
TOOL=$(echo "$INPUT_LINE" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('tool_name',''))" 2>/dev/null)

# Only state-changing actions
case "$TOOL" in
    Edit|Write|Bash|NotebookEdit)
        ;;
    *)
        exit 0
        ;;
esac

# Extract brief detail
case "$TOOL" in
    Edit|Write)
        DETAIL=$(echo "$INPUT_LINE" | python3 -c "
import sys,json,os
d=json.load(sys.stdin)
fp = d.get('tool_input',{}).get('file_path','?')
print(os.path.basename(fp))
" 2>/dev/null)
        ;;
    Bash)
        DETAIL=$(echo "$INPUT_LINE" | python3 -c "
import sys,json
d=json.load(sys.stdin)
cmd = d.get('tool_input',{}).get('command','')
print(cmd.split('\n')[0][:60])
" 2>/dev/null)
        ;;
    *)
        DETAIL=""
        ;;
esac

NOW=$(date '+%H:%M' 2>/dev/null || echo "??:??")

# Create file if it doesn't exist
if [ ! -f "$THREAD_FILE" ]; then
    cat > "$THREAD_FILE" << EOF
# Session Thread
> Thread of the current session. Auto-updated.
> Read by post-compact to resume without losing trajectory.

## Current task
(no task set — update with: bash {{PROJECT_DIR}}/.claude/hooks/thread_task.sh "task description")

## Recent actions
EOF
fi

# Append action
echo "- [$NOW] $TOOL: $DETAIL" >> "$THREAD_FILE"

# Truncate to MAX_ACTIONS (keep header + task + last N actions)
TOTAL_LINES=$(wc -l < "$THREAD_FILE")
ACTIONS_START=$(grep -n "^## Recent actions" "$THREAD_FILE" | tail -1 | cut -d: -f1)
if [ -n "$ACTIONS_START" ]; then
    ACTIONS_COUNT=$((TOTAL_LINES - ACTIONS_START))
    if [ "$ACTIONS_COUNT" -gt "$MAX_ACTIONS" ]; then
        HEADER=$(head -n "$ACTIONS_START" "$THREAD_FILE")
        TAIL=$(tail -n "$MAX_ACTIONS" "$THREAD_FILE")
        echo "$HEADER" > "$THREAD_FILE"
        echo "$TAIL" >> "$THREAD_FILE"
    fi
fi

exit 0
