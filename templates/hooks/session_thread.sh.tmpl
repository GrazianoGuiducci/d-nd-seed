#!/bin/bash
# ============================================================================
# SESSION THREAD — Mechanical Action Log
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# PostToolUse hook (Edit|Write|Bash): records last actions.
# Complements session_continuum.md (semantic) with mechanical trace.
# Included in pre-compact snapshot. Resets daily.
# ============================================================================

THREAD_FILE="{{PROJECT_DIR}}/.claude/hooks/session_thread.md"
MAX_ACTIONS=15

# Read input JSON from hook
read -t 2 INPUT_LINE 2>/dev/null || INPUT_LINE=""

# Extract tool name
TOOL=$(echo "$INPUT_LINE" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('tool_name',''))" 2>/dev/null)

# Only state-changing actions
case "$TOOL" in
    Edit|Write|Bash|NotebookEdit)
        ;;
    *)
        exit 0
        ;;
esac

# Extract brief detail
case "$TOOL" in
    Edit|Write)
        DETAIL=$(echo "$INPUT_LINE" | python3 -c "
import sys,json,os
d=json.load(sys.stdin)
fp = d.get('tool_input',{}).get('file_path','?')
print(os.path.basename(fp))
" 2>/dev/null)
        ;;
    Bash)
        DETAIL=$(echo "$INPUT_LINE" | python3 -c "
import sys,json
d=json.load(sys.stdin)
cmd = d.get('tool_input',{}).get('command','')
print(cmd.split('\n')[0][:60])
" 2>/dev/null)
        ;;
    *)
        DETAIL=""
        ;;
esac

NOW=$(date '+%H:%M' 2>/dev/null || echo "??:??")
TODAY=$(date '+%Y-%m-%d' 2>/dev/null || echo "unknown")

# Create or reset on new day
NEEDS_RESET=false
if [ ! -f "$THREAD_FILE" ]; then
    NEEDS_RESET=true
else
    FILE_DATE=$(head -3 "$THREAD_FILE" | grep -oP '\d{4}-\d{2}-\d{2}' | head -1)
    if [ "$FILE_DATE" != "$TODAY" ]; then
        NEEDS_RESET=true
    fi
fi

if [ "$NEEDS_RESET" = "true" ]; then
    cat > "$THREAD_FILE" << EOF
# Session Thread ($TODAY)
> Mechanical log. Semantic context is in session_continuum.md.

## Actions
EOF
fi

# Append action
echo "- [$NOW] $TOOL: $DETAIL" >> "$THREAD_FILE"

# Truncate to MAX_ACTIONS
TOTAL_LINES=$(wc -l < "$THREAD_FILE")
ACTIONS_START=$(grep -n "^## Actions" "$THREAD_FILE" | tail -1 | cut -d: -f1)
if [ -n "$ACTIONS_START" ]; then
    ACTIONS_COUNT=$((TOTAL_LINES - ACTIONS_START))
    if [ "$ACTIONS_COUNT" -gt "$MAX_ACTIONS" ]; then
        HEADER=$(head -n "$ACTIONS_START" "$THREAD_FILE")
        TAIL=$(tail -n "$MAX_ACTIONS" "$THREAD_FILE")
        echo "$HEADER" > "$THREAD_FILE"
        echo "$TAIL" >> "$THREAD_FILE"
    fi
fi

exit 0
