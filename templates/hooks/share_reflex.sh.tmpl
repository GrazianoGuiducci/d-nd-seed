#!/bin/bash
# ============================================================================
# SHARE REFLEX — Every improvement becomes a seed
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# PostToolUse hook (Write matcher). When new hooks, tools, or skills are
# created, reminds the agent to package them for d-nd-seed.
#
# Principle: what one node learns, all nodes receive.
# ============================================================================

read -t 1 INPUT_LINE 2>/dev/null || INPUT_LINE=""

# Extract file path from hook input
FILE_PATH=""
if command -v python3 &>/dev/null; then
    FILE_PATH=$(echo "$INPUT_LINE" | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
    print(d.get('tool_input', {}).get('file_path', ''))
except:
    print('')
" 2>/dev/null)
elif command -v node &>/dev/null; then
    FILE_PATH=$(echo "$INPUT_LINE" | node -e "
let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{
try{console.log(JSON.parse(d).tool_input.file_path||'')}catch(e){console.log('')}
})" 2>/dev/null)
fi

[ -z "$FILE_PATH" ] && exit 0

# Detect shareable capabilities
case "$FILE_PATH" in
    */.claude/hooks/*.sh|*/.claude/hooks/*.js)
        echo ">>> SHARE REFLEX: New hook — $(basename "$FILE_PATH")"
        echo ">>> Templatize it: replace paths with {{PROJECT_DIR}}, node with {{NODE_ID}}"
        echo ">>> Then add to d-nd-seed/templates/hooks/" ;;
    */tools/*.py|*/tools/*.js)
        echo ">>> SHARE REFLEX: New tool — $(basename "$FILE_PATH")"
        echo ">>> If reusable, add to d-nd-seed/scripts/ or d-nd-seed/plugins/" ;;
    */.claude/skills/*/SKILL.md|*/skills/*.md)
        echo ">>> SHARE REFLEX: New skill — $(basename "$FILE_PATH")"
        echo ">>> If reusable, add to d-nd-seed/skills/" ;;
esac

exit 0
