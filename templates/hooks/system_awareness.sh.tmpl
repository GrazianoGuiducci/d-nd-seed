#!/bin/bash
# ============================================================================
# SYSTEM AWARENESS — Multi-Project Scanner
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# Fires on EVERY SessionStart.
# Scans: active repos, API health, messages.
# Writes persistent state to .claude/hooks/system_state.md
# ============================================================================

PROJECT_DIR="{{PROJECT_DIR}}"
STATE_FILE="$PROJECT_DIR/.claude/hooks/system_state.md"

echo "=== {{NODE_ID}} SYSTEM AWARENESS ==="
echo "Timestamp: $(date '+%Y-%m-%d %H:%M:%S')"
echo ""

{{SINAPSI_BLOCK}}

# --- Active Repos Status ---
echo "## Active Repos"

REPOS=(
{{REPOS_ARRAY}}
)

cat > "$STATE_FILE" << HEADER
# System State — Auto-generated ({{NODE_ID}})
> Last scan: $(date '+%Y-%m-%d %H:%M:%S')

## Repos
| Repo | Commit | Dirty | Untracked |
|------|--------|-------|-----------|
HEADER

for entry in "${REPOS[@]}"; do
    IFS=':' read -r name path branch <<< "$entry"
    dir="$PROJECT_DIR/$path"

    if [ ! -d "$dir/.git" ]; then
        echo "  $name: [no git]"
        echo "| $name | — | — | — |" >> "$STATE_FILE"
        continue
    fi

    commit=$(git -C "$dir" rev-parse --short HEAD 2>/dev/null || echo "???")
    dirty=$(git -C "$dir" diff --name-only 2>/dev/null | wc -l | tr -d ' ')
    untracked=$(git -C "$dir" ls-files --others --exclude-standard 2>/dev/null | wc -l | tr -d ' ')

    status="$commit"
    [ "$dirty" -gt 0 ] 2>/dev/null && status="$status | dirty:$dirty"
    [ "$untracked" -gt 0 ] 2>/dev/null && status="$status | new:$untracked"

    echo "  $name: $status"
    echo "| $name | $commit | $dirty | $untracked |" >> "$STATE_FILE"
done
echo ""

{{EXTRA_HEALTH_CHECKS}}

# --- Warnings ---
echo "## Warnings"
WARN_COUNT=0

for entry in "${REPOS[@]}"; do
    IFS=':' read -r name path branch <<< "$entry"
    dir="$PROJECT_DIR/$path"
    if [ -d "$dir/.git" ]; then
        dirty=$(git -C "$dir" diff --name-only 2>/dev/null | wc -l | tr -d ' ')
        if [ "$dirty" -gt 5 ] 2>/dev/null; then
            echo "  $name: $dirty uncommitted changes"
            WARN_COUNT=$((WARN_COUNT + 1))
        fi
    fi
done

{{EXTRA_WARNINGS}}

[ "$WARN_COUNT" -eq 0 ] && echo "  None."
echo ""

# --- Transcript Recovery (anti-amnesia post-compact) ---
echo "## Recent Conversation (last 15 exchanges)"
JSONL_DIR="{{JSONL_DIR}}"
LATEST_JSONL=$(ls -t "$JSONL_DIR"/*.jsonl 2>/dev/null | head -1)

if [ -n "$LATEST_JSONL" ]; then
    tail -c 512000 "$LATEST_JSONL" 2>/dev/null | python3 -c "
import sys, json
lines = []
for line in sys.stdin:
    line = line.strip()
    if not line: continue
    try:
        obj = json.loads(line)
    except:
        continue
    role = obj.get('type', '')
    if role == 'human':
        msg = ''
        for block in obj.get('message', {}).get('content', []):
            if isinstance(block, dict) and block.get('type') == 'text':
                msg = block['text'][:200]
                break
            elif isinstance(block, str):
                msg = block[:200]
                break
        if msg and not msg.startswith('<'):
            lines.append(('OP', msg.replace(chr(10), ' ')))
    elif role == 'assistant':
        msg = ''
        for block in obj.get('message', {}).get('content', []):
            if isinstance(block, dict) and block.get('type') == 'text':
                msg = block['text'][:200]
                break
        if msg and not msg.startswith('<'):
            lines.append(('{{NODE_ID}}', msg.replace(chr(10), ' ')))

for role, text in lines[-15:]:
    print(f'  [{role}] {text[:150]}')
" 2>/dev/null
else
    echo "  No JSONL transcript found."
fi
echo ""

echo "## Claude Code"
CC_VER=$(claude --version 2>/dev/null || echo "unknown")
echo "  Version: $CC_VER"

echo ""
echo "=== END {{NODE_ID}} SYSTEM AWARENESS ==="
exit 0
