#!/bin/bash
# ============================================================================
# SYSTEM AWARENESS — Multi-Project Scanner
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# Fires on EVERY SessionStart.
# Scans: active repos, API health, messages.
# Writes persistent state to .claude/hooks/system_state.md
# ============================================================================

PROJECT_DIR="{{PROJECT_DIR}}"
STATE_FILE="$PROJECT_DIR/.claude/hooks/system_state.md"

echo "=== {{NODE_ID}} SYSTEM AWARENESS ==="
echo "Timestamp: $(date '+%Y-%m-%d %H:%M:%S')"
echo ""

{{SINAPSI_BLOCK}}

# --- Active Repos Status ---
echo "## Active Repos"

REPOS=(
{{REPOS_ARRAY}}
)

cat > "$STATE_FILE" << HEADER
# System State — Auto-generated ({{NODE_ID}})
> Last scan: $(date '+%Y-%m-%d %H:%M:%S')

## Repos
| Repo | Commit | Dirty | Untracked |
|------|--------|-------|-----------|
HEADER

for entry in "${REPOS[@]}"; do
    IFS=':' read -r name path branch <<< "$entry"
    dir="$PROJECT_DIR/$path"

    if [ ! -d "$dir/.git" ]; then
        echo "  $name: [no git]"
        echo "| $name | — | — | — |" >> "$STATE_FILE"
        continue
    fi

    commit=$(git -C "$dir" rev-parse --short HEAD 2>/dev/null || echo "???")
    dirty=$(git -C "$dir" diff --name-only 2>/dev/null | wc -l | tr -d ' ')
    untracked=$(git -C "$dir" ls-files --others --exclude-standard 2>/dev/null | wc -l | tr -d ' ')

    status="$commit"
    [ "$dirty" -gt 0 ] 2>/dev/null && status="$status | dirty:$dirty"
    [ "$untracked" -gt 0 ] 2>/dev/null && status="$status | new:$untracked"

    echo "  $name: $status"
    echo "| $name | $commit | $dirty | $untracked |" >> "$STATE_FILE"
done
echo ""

{{EXTRA_HEALTH_CHECKS}}

# --- Warnings ---
echo "## Warnings"
WARN_COUNT=0

for entry in "${REPOS[@]}"; do
    IFS=':' read -r name path branch <<< "$entry"
    dir="$PROJECT_DIR/$path"
    if [ -d "$dir/.git" ]; then
        dirty=$(git -C "$dir" diff --name-only 2>/dev/null | wc -l | tr -d ' ')
        if [ "$dirty" -gt 5 ] 2>/dev/null; then
            echo "  $name: $dirty uncommitted changes"
            WARN_COUNT=$((WARN_COUNT + 1))
        fi
    fi
done

{{EXTRA_WARNINGS}}

[ "$WARN_COUNT" -eq 0 ] && echo "  None."
echo ""

echo "## Claude Code"
CC_VER=$(claude --version 2>/dev/null || echo "unknown")
echo "  Version: $CC_VER"

echo ""
echo "=== END {{NODE_ID}} SYSTEM AWARENESS ==="
exit 0
