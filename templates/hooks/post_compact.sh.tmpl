#!/bin/bash
# ============================================================================
# POST-COMPACT — Lagrangian Context Re-injection
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# Fires on SessionStart AFTER compaction.
# Prints saved context to stdout → injected into Claude's conversation.
# ============================================================================

PROJECT_DIR="{{PROJECT_DIR}}"
CONTEXT_FILE="$PROJECT_DIR/.claude/hooks/active_context.md"
REASONING_FILE="$PROJECT_DIR/.claude/hooks/active_reasoning.md"

if [ -f "$CONTEXT_FILE" ]; then
    echo "=== LAGRANGIAN CONTEXT RESTORED [{{NODE_ID}}] ==="
    echo ""
    while IFS= read -r line; do
        echo "$line"
    done < "$CONTEXT_FILE"
    echo ""
    echo "=== END LAGRANGIAN CONTEXT ==="
    echo ""

    if [ -f "$REASONING_FILE" ]; then
        echo "=== REASONING CHAIN ==="
        echo ""
        while IFS= read -r line; do
            echo "$line"
        done < "$REASONING_FILE"
        echo ""
        echo "=== END REASONING CHAIN ==="
        echo ""
    fi

    # --- Operator Voice: the actual direction ---
    VOICE_FILE="$PROJECT_DIR/.claude/hooks/operator_voice.md"
    if [ -f "$VOICE_FILE" ]; then
        echo "=== OPERATOR VOICE (verbatim, last 15 messages) ==="
        echo ""
        while IFS= read -r line; do
            echo "$line"
        done < "$VOICE_FILE"
        echo ""
        echo "=== END OPERATOR VOICE ==="
        echo ""
    fi

    echo "IMPORTANT: Context was compacted. The snapshot above was captured"
    echo "BEFORE compaction. Resume by:"
    echo "  1. Reading OPERATOR VOICE above — those words ARE the direction"
    echo "  2. Do NOT convert the operator's words into a task list"
    echo "  3. Uncommitted changes (git diff in dirty repos)"
    echo "  4. Todo list for in-progress tasks"
    echo "  5. STOP and OBSERVE before acting — find where the spiral was pointing"
else
    echo "=== POST-COMPACTION: No pre-compact snapshot found ==="
    echo ""
    for R in {{PRIMARY_REPOS}}; do
        RPATH="$PROJECT_DIR/$R"
        if [ -d "$RPATH/.git" ]; then
            echo "$R: $(git -C "$RPATH" log --oneline -1 2>/dev/null)"
        fi
    done
fi

exit 0
