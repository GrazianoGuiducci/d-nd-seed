#!/bin/bash
# ============================================================================
# POST-COMPACT — Lagrangian Context Re-injection
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# Fires on SessionStart AFTER compaction.
# Prints saved context to stdout -> injected into Claude's conversation.
#
# active_context.md now includes session_thread (semantic context).
# Operator voice is injected separately if available.
# ============================================================================

PROJECT_DIR="{{PROJECT_DIR}}"
CONTEXT_FILE="$PROJECT_DIR/.claude/hooks/active_context.md"

if [ -f "$CONTEXT_FILE" ]; then
    echo "=== LAGRANGIAN CONTEXT RESTORED [{{NODE_ID}}] ==="
    echo ""
    cat "$CONTEXT_FILE"
    echo ""
    echo "=== END LAGRANGIAN CONTEXT ==="
    echo ""

    # --- Operator Voice: the actual direction ---
    VOICE_FILE="$PROJECT_DIR/.claude/hooks/operator_voice.md"
    if [ -f "$VOICE_FILE" ]; then
        echo "=== OPERATOR VOICE (verbatim, last 15 messages) ==="
        echo ""
        cat "$VOICE_FILE"
        echo ""
        echo "=== END OPERATOR VOICE ==="
        echo ""
    fi

    echo "IMPORTANT: Context was compacted. The SESSION THREAD in the snapshot"
    echo "shows what you were doing. Resume from there."
    echo "If the thread is empty, check:"
    echo "  1. OPERATOR VOICE above — those words ARE the direction"
    echo "  2. Uncommitted changes (git diff in dirty repos)"
    echo "  3. Todo list for in-progress tasks"
    echo ""
    echo "=== REFLECTIVE CHECKLIST (before resuming the next act) ==="
    echo "A re-injected snapshot carries the titles, not always the nuance."
    echo "Before acting, verify each item explicitly:"
    echo "  1. 'In progress' — what was the PRECISE state of active tasks?"
    echo "     (not just the titles — the half-step, the next line, the pending verify)"
    echo "  2. Tools considered and rejected — why were they rejected?"
    echo "     (the rejection reasons are easy to lose; reconsider whether they still hold)"
    echo "  3. Invisible rules not in the code — data shapes, dedup keys, caps, thresholds,"
    echo "     normalization rules. These are 'load-bearing' but rarely documented."
    echo "  4. File ownership — who curates what. Do not touch files owned by other agents"
    echo "     without the agreed-upon handshake."
    echo "  5. Recent bug fixes — can they resurface? (case-sensitivity, race conditions,"
    echo "     timing, silent failures). Re-verify the fix is still in place."
    echo "  6. Application state files — runtime state that lives outside git. If it"
    echo "     was restored from the snapshot, it may be stale."
    echo "  7. Concrete priorities among open tasks — not all urgent equally. The operator"
    echo "     may have signaled an order before the compact."
    echo ""
    echo "If the snapshot above does NOT contain clear answers to these seven questions,"
    echo "ask the operator 'what might I have missed?' before proceeding."
else
    echo "=== POST-COMPACTION: No pre-compact snapshot found ==="
    echo ""
    for R in {{PRIMARY_REPOS}}; do
        RPATH="$PROJECT_DIR/$R"
        if [ -d "$RPATH/.git" ]; then
            echo "$R: $(git -C "$RPATH" log --oneline -1 2>/dev/null)"
        fi
    done
fi

exit 0

