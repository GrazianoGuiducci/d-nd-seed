#!/usr/bin/env python3
"""
continuum_extract.py — Fallback: extract last exchange from .jsonl session files.

Generated by d-nd-seed for node: {{NODE_ID}}

Used by system_awareness.sh when session_continuum.md is stale (>6h).
Reads the most recent .jsonl, extracts last N user+assistant messages.
Output: markdown summary to stdout.
"""
import json
import os
import sys
import glob
import time

SESSION_DIR = "{{SESSION_DIR}}"
MAX_READ_BYTES = 500_000
MAX_USER_MSGS = 5
MAX_ASSISTANT_MSGS = 3
MAX_TEXT_LEN = 500


def find_latest_session(skip_fresh=True):
    """Find the most recent .jsonl with substantial content.

    skip_fresh: if True, skip files modified in the last 60 seconds
    (likely the current session that just started — we want the previous one).
    """
    pattern = os.path.join(SESSION_DIR, "*.jsonl")
    files = glob.glob(pattern)
    if not files:
        return None
    files.sort(key=lambda f: os.path.getmtime(f), reverse=True)
    now = time.time()
    for f in files:
        size = os.path.getsize(f)
        age = now - os.path.getmtime(f)
        if size < 10_000:
            continue
        if skip_fresh and age < 60:
            continue
        return f
    for f in files:
        if os.path.getsize(f) > 10_000:
            return f
    return files[0] if files else None


def extract_messages(filepath):
    """Extract user and assistant text messages from tail of session."""
    size = os.path.getsize(filepath)
    offset = max(0, size - MAX_READ_BYTES)

    messages = []
    with open(filepath, "rb") as f:
        f.seek(offset)
        data = f.read().decode("utf-8", errors="replace")

    for line in data.split("\n"):
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
        except (json.JSONDecodeError, ValueError):
            continue

        msg_type = obj.get("type", "")
        if msg_type not in ("user", "assistant"):
            continue

        message = obj.get("message", {})
        if not isinstance(message, dict):
            continue

        content = message.get("content", "")
        if isinstance(content, list):
            texts = []
            for c in content:
                if isinstance(c, dict) and c.get("type") == "text":
                    t = c.get("text", "")
                    if "<system-reminder>" in t[:50]:
                        continue
                    texts.append(t)
            content = " ".join(texts)

        if not content or not content.strip():
            continue
        clean = content.strip()
        if len(clean) < 10:
            continue

        messages.append({
            "role": msg_type,
            "text": clean
        })

    return messages


def format_output(messages, filepath):
    """Format extracted messages as markdown."""
    session_id = os.path.basename(filepath).replace(".jsonl", "")[:8]
    mtime = os.path.getmtime(filepath)
    age_h = (time.time() - mtime) / 3600

    user_msgs = [m for m in messages if m["role"] == "user"][-MAX_USER_MSGS:]
    asst_msgs = [m for m in messages if m["role"] == "assistant"][-MAX_ASSISTANT_MSGS:]

    print(f"## Last Session Extract (fallback)")
    print(f"> Session: {session_id}... | Age: {age_h:.1f}h")
    print()

    if user_msgs:
        print("### Ultime richieste operatore")
        for m in user_msgs:
            text = m["text"][:MAX_TEXT_LEN]
            if len(m["text"]) > MAX_TEXT_LEN:
                text += "..."
            print(f"> {text}")
            print()

    if asst_msgs:
        print("### Ultimo stato {{NODE_ID}}")
        for m in asst_msgs:
            text = m["text"][:MAX_TEXT_LEN]
            if len(m["text"]) > MAX_TEXT_LEN:
                text += "..."
            print(text)
            print()


def main():
    filepath = find_latest_session()
    if not filepath:
        print("No session files found.")
        return

    messages = extract_messages(filepath)
    if not messages:
        print("No messages extracted from last session.")
        return

    format_output(messages, filepath)


if __name__ == "__main__":
    main()
