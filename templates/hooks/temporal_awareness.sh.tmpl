#!/bin/bash
# ============================================================================
# TEMPORAL AWARENESS — Knowledge Cutoff Guard
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# PreToolUse hook for Bash and Write.
# Detects when the AI is about to produce content or execute commands
# that depend on temporal knowledge (versions, APIs, tools, pricing).
# Does NOT block — injects a reminder to verify.
# ============================================================================

INPUT=$(cat)

TOOL_NAME=$(echo "$INPUT" | node -e "const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.tool_name||'')" 2>/dev/null)
TOOL_INPUT=$(echo "$INPUT" | node -e "const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(JSON.stringify(d.tool_input||{}))" 2>/dev/null)

WARNING=""

if [ "$TOOL_NAME" = "Bash" ]; then
    COMMAND=$(echo "$TOOL_INPUT" | node -e "const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.command||'')" 2>/dev/null)

    # Package install with specific versions
    if echo "$COMMAND" | grep -qiE 'npm install|pip install|gem install|cargo add|go get|apt install|brew install'; then
        WARNING="TEMPORAL: You are installing packages. Verify that the package names and versions are current. Your training data may reference outdated versions."
    fi

    # curl to external APIs (not local)
    if echo "$COMMAND" | grep -qiE 'curl.*https?://[^l][^o][^c]' | head -c 0; then true; fi
    if echo "$COMMAND" | grep -qiE 'curl\s.*https?://' && ! echo "$COMMAND" | grep -qiE 'localhost|127\.0\.0\.1|0\.0\.0\.0'; then
        WARNING="TEMPORAL: External API call. Verify that the endpoint, auth method, and payload format are current."
    fi

fi

if [ "$TOOL_NAME" = "Write" ]; then
    FILE_PATH=$(echo "$TOOL_INPUT" | node -e "const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.file_path||'')" 2>/dev/null)
    CONTENT=$(echo "$TOOL_INPUT" | node -e "const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.content||'')" 2>/dev/null)

    # Writing config files that reference versions
    if echo "$FILE_PATH" | grep -qiE 'package\.json|requirements\.txt|Gemfile|Cargo\.toml|go\.mod|pyproject\.toml|pom\.xml'; then
        WARNING="TEMPORAL: You are writing a dependency file. Package versions may be outdated. Check current stable versions before committing."
    fi

    # Writing documentation with version references
    if echo "$CONTENT" | grep -qiE 'version [0-9]+\.[0-9]+|v[0-9]+\.[0-9]+\.[0-9]+'; then
        if echo "$FILE_PATH" | grep -qiE '\.md$|\.html$|\.txt$'; then
            WARNING="TEMPORAL: Content references specific versions. Verify these are current before publishing."
        fi
    fi

    # Writing content that mentions pricing, plans, or features of external services
    if echo "$CONTENT" | grep -qiE 'pricing|free tier|free plan|per month|\$/month|enterprise plan|pro plan|starter plan'; then
        WARNING="TEMPORAL: Content references pricing or plans of external services. These change frequently. Verify before publishing."
    fi
fi

if [ -n "$WARNING" ]; then
    node -e "
const w = process.argv[1];
console.log(JSON.stringify({
    hookSpecificOutput: {
        hookEventName: 'PreToolUse',
        additionalContext: 'TEMPORAL AWARENESS [{{NODE_ID}}]: ' + w
    }
}));
" "$WARNING"
fi

exit 0

