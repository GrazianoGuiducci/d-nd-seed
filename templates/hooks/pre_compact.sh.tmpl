#!/bin/bash
# ============================================================================
# PRE-COMPACT — Lagrangian Context Capture
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# Fires BEFORE compaction. Captures critical state to active_context.md.
#
# Principle: not everything has the same informational weight.
# Lagrangian variables (identity, decisions, task state) survive.
# Redundant coordinates (command output, failed attempts) get dropped.
# ============================================================================

read -t 1 INPUT_LINE 2>/dev/null || INPUT_LINE=""

PROJECT_DIR="{{PROJECT_DIR}}"
CONTEXT_FILE="$PROJECT_DIR/.claude/hooks/active_context.md"
NOW=$(date '+%Y-%m-%d %H:%M' 2>/dev/null || echo "unknown")

# --- Gather git state for a repo ---
repo_state() {
    REPO_NAME=$1
    REPO_PATH=$2

    if [ ! -d "$REPO_PATH/.git" ]; then
        return
    fi

    BRANCH=$(git -C "$REPO_PATH" branch --show-current 2>/dev/null || echo "unknown")
    LAST_COMMIT=$(git -C "$REPO_PATH" log --oneline -1 2>/dev/null || echo "none")
    DIRTY=$(git -C "$REPO_PATH" diff --name-only 2>/dev/null)
    STAGED=$(git -C "$REPO_PATH" diff --cached --name-only 2>/dev/null)
    UNTRACKED=$(git -C "$REPO_PATH" ls-files --others --exclude-standard 2>/dev/null)

    echo "### $REPO_NAME ($BRANCH)" >> "$CONTEXT_FILE"
    echo "- Last commit: \`$LAST_COMMIT\`" >> "$CONTEXT_FILE"

    if [ -n "$DIRTY" ]; then
        echo "- **Uncommitted changes:**" >> "$CONTEXT_FILE"
        echo "$DIRTY" | head -10 | while IFS= read -r f; do echo "  - \`$f\`" >> "$CONTEXT_FILE"; done
    fi
    if [ -n "$STAGED" ]; then
        echo "- **Staged:**" >> "$CONTEXT_FILE"
        echo "$STAGED" | head -10 | while IFS= read -r f; do echo "  - \`$f\`" >> "$CONTEXT_FILE"; done
    fi
    if [ -n "$UNTRACKED" ]; then
        echo "- **Untracked:**" >> "$CONTEXT_FILE"
        echo "$UNTRACKED" | head -10 | while IFS= read -r f; do echo "  - \`$f\`" >> "$CONTEXT_FILE"; done
    fi
    echo "" >> "$CONTEXT_FILE"
}

# --- Detect dirty state ---
HAS_DIRTY=""
{{REPOS_DIRTY_CHECK}}

if [ -n "$HAS_DIRTY" ]; then
    MODE="FILE_EDIT"
else
    MODE="GENERAL"
fi

# --- Gravitational core: most recently touched file ---
PRIMARY_REPO="{{PRIMARY_REPO_PATH}}"
ATTRACTOR=""
TRAJECTORY=""
MOMENTUM=""
if [ -d "$PRIMARY_REPO/.git" ]; then
    ATTRACTOR=$(git -C "$PRIMARY_REPO" diff --name-only 2>/dev/null | head -1)
    if [ -z "$ATTRACTOR" ]; then
        ATTRACTOR=$(git -C "$PRIMARY_REPO" diff --name-only HEAD~1 2>/dev/null | head -1)
    fi
    TRAJECTORY=$(git -C "$PRIMARY_REPO" log --oneline -3 2>/dev/null)
    LAST_TS=$(git -C "$PRIMARY_REPO" log -1 --format=%ct 2>/dev/null)
    if [ -n "$LAST_TS" ]; then
        NOW_TS=$(date +%s 2>/dev/null)
        ELAPSED=$(( (NOW_TS - LAST_TS) / 60 ))
        if [ "$ELAPSED" -lt 30 ] 2>/dev/null; then
            MOMENTUM="active-flow (${ELAPSED}min since last commit)"
        elif [ "$ELAPSED" -lt 120 ] 2>/dev/null; then
            MOMENTUM="warm (${ELAPSED}min since last commit)"
        else
            MOMENTUM="cold (${ELAPSED}min since last commit)"
        fi
    fi
fi

# --- Write context file ---
cat > "$CONTEXT_FILE" << EOF
# Active Context — Lagrangian Snapshot ({{NODE_ID}})
> Pre-compact capture at $NOW | Mode: $MODE | Node: {{NODE_ID}}
> Re-injected after compaction to restore critical state.

## Field State
- **Attractor** (gravitational center): \`${ATTRACTOR:-none}\`
- **Momentum**: ${MOMENTUM:-unknown}
- **Trajectory** (last 3 commits):
EOF

echo "$TRAJECTORY" | while IFS= read -r line; do
    echo "  - \`$line\`" >> "$CONTEXT_FILE"
done
echo "" >> "$CONTEXT_FILE"

echo "## Repository State" >> "$CONTEXT_FILE"

{{REPOS_STATE_CALLS}}

cat >> "$CONTEXT_FILE" << 'EOF'
## Recovery Instructions
- Check todo list for in-progress tasks
- If files have uncommitted changes, run `git diff` before proceeding
- Read project memory files for persistent context
EOF

if [ "$MODE" = "FILE_EDIT" ]; then
    echo "" >> "$CONTEXT_FILE"
    echo "## File Edit Mode Active" >> "$CONTEXT_FILE"
    echo "There are uncommitted changes. Check diffs carefully before proceeding." >> "$CONTEXT_FILE"
fi

# --- Semantic tags: detect unpushed commits ---
SEMANTIC_TAGS=""
{{REPOS_SEMANTIC_CHECK}}
if [ -n "$SEMANTIC_TAGS" ]; then
    echo "" >> "$CONTEXT_FILE"
    echo "### Semantic Tags: $SEMANTIC_TAGS" >> "$CONTEXT_FILE"
fi

echo "[PRE_COMPACT] Context saved (node={{NODE_ID}}, mode=$MODE, tags=${SEMANTIC_TAGS:-none})" >&2
