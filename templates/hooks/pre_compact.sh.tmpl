#!/bin/bash
# ============================================================================
# PRE-COMPACT — Lagrangian Context Capture
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# Fires BEFORE compaction. Captures critical state to active_context.md.
#
# Principle: not everything has the same informational weight.
# Lagrangian variables (identity, decisions, task state) survive.
# Redundant coordinates (command output, failed attempts) get dropped.
# ============================================================================

read -t 1 INPUT_LINE 2>/dev/null || INPUT_LINE=""

PROJECT_DIR="{{PROJECT_DIR}}"
CONTEXT_FILE="$PROJECT_DIR/.claude/hooks/active_context.md"
NOW=$(date '+%Y-%m-%d %H:%M' 2>/dev/null || echo "unknown")

# --- Gather git state for a repo ---
repo_state() {
    REPO_NAME=$1
    REPO_PATH=$2

    if [ ! -d "$REPO_PATH/.git" ]; then
        return
    fi

    BRANCH=$(git -C "$REPO_PATH" branch --show-current 2>/dev/null || echo "unknown")
    LAST_COMMIT=$(git -C "$REPO_PATH" log --oneline -1 2>/dev/null || echo "none")
    DIRTY=$(git -C "$REPO_PATH" diff --name-only 2>/dev/null)
    STAGED=$(git -C "$REPO_PATH" diff --cached --name-only 2>/dev/null)
    UNTRACKED=$(git -C "$REPO_PATH" ls-files --others --exclude-standard 2>/dev/null)

    echo "### $REPO_NAME ($BRANCH)" >> "$CONTEXT_FILE"
    echo "- Last commit: \`$LAST_COMMIT\`" >> "$CONTEXT_FILE"

    if [ -n "$DIRTY" ]; then
        echo "- **Uncommitted changes:**" >> "$CONTEXT_FILE"
        echo "$DIRTY" | head -10 | while IFS= read -r f; do echo "  - \`$f\`" >> "$CONTEXT_FILE"; done
    fi
    if [ -n "$STAGED" ]; then
        echo "- **Staged:**" >> "$CONTEXT_FILE"
        echo "$STAGED" | head -10 | while IFS= read -r f; do echo "  - \`$f\`" >> "$CONTEXT_FILE"; done
    fi
    if [ -n "$UNTRACKED" ]; then
        echo "- **Untracked:**" >> "$CONTEXT_FILE"
        echo "$UNTRACKED" | head -10 | while IFS= read -r f; do echo "  - \`$f\`" >> "$CONTEXT_FILE"; done
    fi
    echo "" >> "$CONTEXT_FILE"
}

# --- Detect dirty state ---
HAS_DIRTY=""
{{REPOS_DIRTY_CHECK}}

if [ -n "$HAS_DIRTY" ]; then
    MODE="FILE_EDIT"
else
    MODE="GENERAL"
fi

# --- Gravitational core: most recently touched file ---
PRIMARY_REPO="{{PRIMARY_REPO_PATH}}"
ATTRACTOR=""
TRAJECTORY=""
MOMENTUM=""
if [ -d "$PRIMARY_REPO/.git" ]; then
    ATTRACTOR=$(git -C "$PRIMARY_REPO" diff --name-only 2>/dev/null | head -1)
    if [ -z "$ATTRACTOR" ]; then
        ATTRACTOR=$(git -C "$PRIMARY_REPO" diff --name-only HEAD~1 2>/dev/null | head -1)
    fi
    TRAJECTORY=$(git -C "$PRIMARY_REPO" log --oneline -3 2>/dev/null)
    LAST_TS=$(git -C "$PRIMARY_REPO" log -1 --format=%ct 2>/dev/null)
    if [ -n "$LAST_TS" ]; then
        NOW_TS=$(date +%s 2>/dev/null)
        ELAPSED=$(( (NOW_TS - LAST_TS) / 60 ))
        if [ "$ELAPSED" -lt 30 ] 2>/dev/null; then
            MOMENTUM="active-flow (${ELAPSED}min since last commit)"
        elif [ "$ELAPSED" -lt 120 ] 2>/dev/null; then
            MOMENTUM="warm (${ELAPSED}min since last commit)"
        else
            MOMENTUM="cold (${ELAPSED}min since last commit)"
        fi
    fi
fi

# --- Write context file ---
cat > "$CONTEXT_FILE" << EOF
# Active Context — Lagrangian Snapshot ({{NODE_ID}})
> Pre-compact capture at $NOW | Mode: $MODE | Node: {{NODE_ID}}
> Re-injected after compaction to restore critical state.

## Field State
- **Attractor** (gravitational center): \`${ATTRACTOR:-none}\`
- **Momentum**: ${MOMENTUM:-unknown}
- **Trajectory** (last 3 commits):
EOF

echo "$TRAJECTORY" | while IFS= read -r line; do
    echo "  - \`$line\`" >> "$CONTEXT_FILE"
done
echo "" >> "$CONTEXT_FILE"

echo "## Repository State" >> "$CONTEXT_FILE"

{{REPOS_STATE_CALLS}}

# --- Session Continuum (semantic context — direction, last request, insights) ---
CONTINUUM_FILE="$PROJECT_DIR/.claude/hooks/session_continuum.md"
if [ -f "$CONTINUUM_FILE" ]; then
    echo "" >> "$CONTEXT_FILE"
    echo "## Session Continuum (pre-compact snapshot)" >> "$CONTEXT_FILE"
    cat "$CONTINUUM_FILE" >> "$CONTEXT_FILE"
    echo "" >> "$CONTEXT_FILE"
else
    # Fallback: extract from .jsonl
    EXTRACT=$(python3 "$PROJECT_DIR/.claude/hooks/continuum_extract.py" 2>/dev/null | head -40)
    if [ -n "$EXTRACT" ]; then
        echo "" >> "$CONTEXT_FILE"
        echo "## Session Continuum (extracted from .jsonl)" >> "$CONTEXT_FILE"
        echo "$EXTRACT" >> "$CONTEXT_FILE"
        echo "" >> "$CONTEXT_FILE"
    fi
fi

# --- Session Thread (mechanical action log) ---
THREAD_FILE="$PROJECT_DIR/.claude/hooks/session_thread.md"
if [ -f "$THREAD_FILE" ]; then
    echo "" >> "$CONTEXT_FILE"
    echo "## Session Thread (mechanical log)" >> "$CONTEXT_FILE"
    cat "$THREAD_FILE" >> "$CONTEXT_FILE"
    echo "" >> "$CONTEXT_FILE"
fi

cat >> "$CONTEXT_FILE" << 'EOF'
## Recovery Instructions
- Check todo list for in-progress tasks
- If files have uncommitted changes, run `git diff` before proceeding
- Read session_continuum.md for semantic context (where we were, what was asked)
- Read project memory files for persistent context
EOF

if [ "$MODE" = "FILE_EDIT" ]; then
    echo "" >> "$CONTEXT_FILE"
    echo "## File Edit Mode Active" >> "$CONTEXT_FILE"
    echo "There are uncommitted changes. Check diffs carefully before proceeding." >> "$CONTEXT_FILE"
fi

# --- Semantic tags: detect unpushed commits ---
SEMANTIC_TAGS=""
{{REPOS_SEMANTIC_CHECK}}
if [ -n "$SEMANTIC_TAGS" ]; then
    echo "" >> "$CONTEXT_FILE"
    echo "### Semantic Tags: $SEMANTIC_TAGS" >> "$CONTEXT_FILE"
fi

# --- Operator Voice: last 15 user messages from transcript ---
# Preserves the DIRECTION, not just the state.
VOICE_FILE="$PROJECT_DIR/.claude/hooks/operator_voice.md"
SESSION_DIR="{{SESSION_DIR}}"

TRANSCRIPT=$(ls -t "$SESSION_DIR"/*.jsonl 2>/dev/null | head -1)
if [ -n "$TRANSCRIPT" ] && [ -f "$TRANSCRIPT" ]; then
    SESSION_DIR_PY="$SESSION_DIR" python3 << 'PYEOF' > "$VOICE_FILE" 2>/dev/null
import json, sys, glob, os

session_dir = os.environ.get("SESSION_DIR_PY", "")
if not session_dir:
    sys.exit(0)
transcripts = sorted(glob.glob(os.path.join(session_dir, "*.jsonl")), key=os.path.getmtime, reverse=True)
if not transcripts:
    sys.exit(0)
transcript = transcripts[0]

msgs = []
with open(transcript, encoding='utf-8', errors='replace') as f:
    for line in f:
        try:
            obj = json.loads(line)
            if obj.get("type") == "user":
                msg = obj.get("message", {})
                content = msg.get("content", "") if isinstance(msg, dict) else str(msg)
                texts = []
                if isinstance(content, list):
                    for block in content:
                        if isinstance(block, dict) and block.get("type") == "text":
                            t = block["text"].strip()
                            if t and len(t) > 3 and "<system" not in t and "<available" not in t and "<task-" not in t:
                                if not t.startswith("This session is being continued") and not t.startswith("Tool loaded"):
                                    texts.append(t[:400])
                elif isinstance(content, str):
                    t = content.strip()
                    if t and len(t) > 3 and "<system" not in t and "<available" not in t:
                        if not t.startswith("This session is being continued"):
                            texts.append(t[:400])
                if texts:
                    msgs.append("\n".join(texts))
        except:
            pass

recent = [m for m in msgs if m not in ("Tool loaded.", "Tool loaded")][-15:]
print("# Operator Voice (last 15 messages)")
print("> Verbatim — do NOT summarize. These are the DIRECTION, not data.")
print()
for i, m in enumerate(recent, 1):
    print(f"[{i}] {m}")
    print()
PYEOF

    # Also extract WHY — the reasoning behind actions (last 5 assistant text blocks)
    SESSION_DIR_PY="$SESSION_DIR" python3 << 'PYEOF2' >> "$VOICE_FILE" 2>/dev/null
import json, glob, os

session_dir = os.environ.get("SESSION_DIR_PY", "")
if not session_dir:
    exit(0)
transcripts = sorted(glob.glob(os.path.join(session_dir, "*.jsonl")), key=os.path.getmtime, reverse=True)
if not transcripts:
    exit(0)
transcript = transcripts[0]

reasons = []
with open(transcript, encoding='utf-8', errors='replace') as f:
    for line in f:
        try:
            obj = json.loads(line)
            if obj.get("type") == "assistant":
                msg = obj.get("message", {})
                content = msg.get("content", "") if isinstance(msg, dict) else ""
                if isinstance(content, list):
                    for block in content:
                        if isinstance(block, dict) and block.get("type") == "text":
                            t = block["text"].strip()
                            if t and len(t) > 80 and not t.startswith("{") and not t.startswith("["):
                                reasons.append(t[:500])
                elif isinstance(content, str) and len(content) > 80:
                    reasons.append(content.strip()[:500])
        except:
            pass

recent = reasons[-5:]
if recent:
    print()
    print("# Why (last 5 reasoning blocks)")
    print("> The reasoning behind the actions — what was being understood.")
    print()
    for i, r in enumerate(recent, 1):
        print(f"[R{i}] {r}")
        print()
PYEOF2

    echo "" >> "$CONTEXT_FILE"
    echo "## Operator Voice + Why" >> "$CONTEXT_FILE"
    echo "Saved to operator_voice.md — READ THIS FIRST after compact." >> "$CONTEXT_FILE"
    echo "The operator's words ARE the direction. The 'why' blocks show the reasoning." >> "$CONTEXT_FILE"
    echo "Do not reinterpret into tasks. Find where the spiral was pointing." >> "$CONTEXT_FILE"
fi

echo "[PRE_COMPACT] Context saved (node={{NODE_ID}}, mode=$MODE, tags=${SEMANTIC_TAGS:-none})" >&2
