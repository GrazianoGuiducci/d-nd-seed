#!/usr/bin/env node
// ============================================================================
// STATUSLINE BRIDGE — Context Window Monitor
// ============================================================================
// Generated by d-nd-seed for node: {{NODE_ID}}
// Reads Claude Code statusLine JSON (stdin), writes context_bridge.json.
// Other hooks (context_awareness.sh) read the bridge file.
//
// Claude Code sends: context_window.used_percentage, model.*, cost.*
// ============================================================================

const fs = require('fs');
const path = require('path');

const BRIDGE_FILE = path.join('{{PROJECT_DIR}}', '.claude', 'hooks', 'context_bridge.json');

let input = '';
process.stdin.setEncoding('utf8');
process.stdin.on('data', chunk => { input += chunk; });
process.stdin.on('end', () => {
    try {
        const data = JSON.parse(input);
        const cw = data.context_window || {};
        const contextPercent = cw.used_percentage || 0;
        const remaining = cw.remaining_percentage || (100 - contextPercent);
        const totalTokens = cw.total_input_tokens || 0;
        const windowSize = cw.context_window_size || 200000;
        const model = (data.model && data.model.display_name) || 'unknown';
        const modelId = (data.model && data.model.id) || '';
        const cost = (data.cost && data.cost.total_cost_usd) || 0;

        let phase = 'EARLY';
        if (contextPercent >= 95) phase = 'CRITICAL';
        else if (contextPercent >= 85) phase = 'WRAP_UP';
        else if (contextPercent >= 70) phase = 'LATE';
        else if (contextPercent >= 30) phase = 'MID';

        const bridge = {
            contextPercent, remaining, totalTokens, windowSize,
            phase, model, modelId, cost,
            timestamp: new Date().toISOString(),
            node: '{{NODE_ID}}'
        };

        fs.writeFileSync(BRIDGE_FILE, JSON.stringify(bridge, null, 2));

        const bar = '#'.repeat(Math.floor(contextPercent / 10)) +
                    '.'.repeat(10 - Math.floor(contextPercent / 10));
        console.log(`[${model}] ${bar} ${contextPercent}% [${phase}] $${cost.toFixed(3)}`);
    } catch (e) {
        process.exit(0);
    }
});

