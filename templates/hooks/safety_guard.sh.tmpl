#!/bin/bash
# ============================================================================
# SAFETY GUARD — PreToolUse Awareness Trigger
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# Fires before Bash/Edit/Write. Checks dangerous patterns, injects warning.
# Does NOT block — reminds.
# ============================================================================

INPUT=$(cat)

TOOL_NAME=$(echo "$INPUT" | node -e "const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.tool_name||'')" 2>/dev/null)
TOOL_INPUT=$(echo "$INPUT" | node -e "const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(JSON.stringify(d.tool_input||{}))" 2>/dev/null)

WARNING=""

if [ "$TOOL_NAME" = "Bash" ]; then
    COMMAND=$(echo "$TOOL_INPUT" | node -e "const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.command||'')" 2>/dev/null)

    # Destructive git operations
    if echo "$COMMAND" | grep -qiE 'git\s+(push\s+--force|reset\s+--hard|clean\s+-f|branch\s+-D)'; then
        WARNING="DESTRUCTIVE GIT: This command can destroy work. Are you sure? Verify with the operator."
    fi

    # Production container operations
    if echo "$COMMAND" | grep -qiE 'docker\s+(rm|stop|kill)|rm\s+-rf\s+/opt'; then
        WARNING="PRODUCTION DANGER: This command impacts the production container. Confirm with the operator."
    fi

    # Deleting important files
    if echo "$COMMAND" | grep -qiE 'rm\s+-rf|rm\s+.*\.(js|json|md|env)'; then
        WARNING="FILE DELETE: You are deleting files. Are you sure they are not needed? Verify first."
    fi

    # Docker restart
    if echo "$COMMAND" | grep -qiE 'docker\s+restart'; then
        WARNING="CONTAINER RESTART: The container will restart. Service will be offline briefly."
    fi

    # Modifying .env files
    if echo "$COMMAND" | grep -qiE '(sed|echo|cat).*\.env'; then
        WARNING="ENV MODIFICATION: You are touching files with secrets. Verify the change is intentional."
    fi

    # Systemd service operations
    if echo "$COMMAND" | grep -qiE 'systemctl\s+(stop|disable|restart)'; then
        WARNING="SERVICE CONTROL: You are modifying a system service. Confirm with the operator."
    fi
fi

if [ "$TOOL_NAME" = "Edit" ] || [ "$TOOL_NAME" = "Write" ]; then
    FILE_PATH=$(echo "$TOOL_INPUT" | node -e "const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.file_path||'')" 2>/dev/null)

    # Critical files (customize this list for your project)
    if echo "$FILE_PATH" | grep -qiE '\.env|CLAUDE\.md|SYSTEM_PROMPT'; then
        WARNING="CRITICAL FILE: You are modifying a core file ($FILE_PATH). Has the operator authorized this?"
    fi
fi

if [ -n "$WARNING" ]; then
    node -e "
const w = process.argv[1];
console.log(JSON.stringify({
    hookSpecificOutput: {
        hookEventName: 'PreToolUse',
        additionalContext: 'SAFETY GUARD [{{NODE_ID}}]: ' + w
    }
}));
" "$WARNING"
fi

exit 0
