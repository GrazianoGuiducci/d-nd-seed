#!/bin/bash
# Messaging Polling Hook — checks for unread messages every 5 minutes
# Triggered on PostToolUse. Lightweight: skips if <5 min since last check.
# Parametric: uses DND_NODE_ID env var for node identity.

TIMESTAMP_FILE="/tmp/dnd_messaging_last_check_${DND_NODE_ID:-node}"
INTERVAL=300
API_URL="http://localhost:3002/api/node-sync?for=${DND_NODE_ID}&unread=true&reader=${DND_NODE_ID}"
API_TOKEN="${DND_API_TOKEN}"

# Check if enough time has passed
if [ -f "$TIMESTAMP_FILE" ]; then
    last_check=$(cat "$TIMESTAMP_FILE" 2>/dev/null || echo 0)
    now=$(date +%s)
    elapsed=$((now - last_check))
    if [ "$elapsed" -lt "$INTERVAL" ]; then
        exit 0
    fi
fi

# Update timestamp
date +%s > "$TIMESTAMP_FILE"

# Query messaging API (timeout 3s to not block)
response=$(curl -s --connect-timeout 3 --max-time 5 \
    -H "X-Auth-Token: $API_TOKEN" \
    "$API_URL" 2>/dev/null)

if [ -z "$response" ]; then
    exit 0
fi

# Count unread
unread_count=$(echo "$response" | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    print(data.get('total', 0))
except:
    print(0)
" 2>/dev/null)

if [ -z "$unread_count" ] || [ "$unread_count" = "0" ]; then
    exit 0
fi

# Extract summary
summary=$(echo "$response" | python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    msgs = data.get('messages', [])
    for m in msgs[:5]:
        src = m.get('from', '?')
        typ = m.get('type', '?')
        ts = m.get('timestamp', '?')[:16]
        # brief (280 char max) has priority over content truncation
        preview = m.get('brief') or str(m.get('content', ''))[:80].replace(chr(10), ' ')
        print(f'  - [{ts}] {src} ({typ}): {preview}')
except:
    pass
" 2>/dev/null)

echo "=== MESSAGING: $unread_count unread message(s) for ${DND_NODE_ID:-node} ==="
if [ -n "$summary" ]; then
    echo "$summary"
fi
echo "=== Check and respond to messages. ==="

