#!/bin/bash
# ============================================================================
# MODUS COPY HOOK — Content positioning guard
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# Fires on PreToolUse (Edit, Write). When writing content, injects
# the modus copy rule into context.
#
# The rule: Position the observer BEFORE the content.
# Pattern: positioning → content → result.
# ============================================================================

INPUT=$(cat)
TOOL_NAME=$(echo "$INPUT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('tool_name',''))" 2>/dev/null)

# Only fire on Edit and Write
if [ "$TOOL_NAME" != "Edit" ] && [ "$TOOL_NAME" != "Write" ]; then
    exit 0
fi

# Check if the file being written is content-related
FILE_PATH=$(echo "$INPUT" | python3 -c "import json,sys; print(json.load(sys.stdin).get('tool_input',{}).get('file_path',''))" 2>/dev/null)
CONTENT=$(echo "$INPUT" | python3 -c "import json,sys; ti=json.load(sys.stdin).get('tool_input',{}); print(ti.get('new_string','') or ti.get('content',''))" 2>/dev/null)

# Detect content writing (pages, articles, copy, descriptions)
IS_CONTENT=false
echo "$FILE_PATH" | grep -qiE "content|page|article|copy|publish|slug" && IS_CONTENT=true
echo "$CONTENT" | grep -qiE "<h[1-6]|<p>|<article|description|title" && IS_CONTENT=true

if [ "$IS_CONTENT" = "false" ]; then
    exit 0
fi

# Inject modus copy rule
cat <<JSONEOF
{
    "hookSpecificOutput": {
        "hookEventName": "PreToolUse",
        "additionalContext": "MODUS COPY: Position the observer BEFORE the content. Pattern: (1) positioning — when needed, in what situation (2) content — what is there (3) result — what is obtained. Never you/tu (inclusive). Never imperatives (accompany). Never describe the tool (say what emerges). Never dual possessives (the field, not your field). Tension is an Entity — the system reads it, does not solve it."
    }
}
JSONEOF

exit 0

# ============================================================================
# ## Eval
#
# ### Trigger Tests
# | Condition | Should fire? | Expected |
# |-----------|-------------|----------|
# | Edit to .tsx with <h2> content | YES | Injects modus copy |
# | Write to .md with <article> | YES | Injects modus copy |
# | Edit to .sh script | NO | Not content |
# | Write to .json config | NO | Not content |
#
# ### Fidelity Tests
# | Condition | Expected behavior |
# |-----------|-------------------|
# | Content detected | JSON with modus copy additionalContext |
# | No content | Silent exit 0 |
# ============================================================================
