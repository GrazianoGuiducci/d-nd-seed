#!/bin/bash
# CEA Hook — Ciclo Esponenziale di Consapevolezza (autologico)
#
# Fires on UserPromptSubmit. Context-aware tool injection.
# Detects WHAT you're working on and provides the RIGHT tools.
# The beehive: the right instrument at the right moment.

TERRITORY_CACHE="/tmp/tm3_territory_cache.json"
COUNT_FILE="/tmp/cea_hook_count"

# Fire every 5th prompt
count=$(cat "$COUNT_FILE" 2>/dev/null || echo 0)
count=$((count + 1))
echo "$count" > "$COUNT_FILE"
[ $((count % 5)) -ne 0 ] && exit 0

output=""

# ─── CONTEXT DETECTION ─────────────────────────────────
# Detect what zone we're working in from recent tool calls

LAST_FILES="/tmp/cea_last_files"
# The hook receives the user prompt on stdin — check for zone keywords
user_input=$(cat 2>/dev/null || echo "")
zone=""

# Diagram zone
if echo "$user_input" | grep -qi "diagram\|diagramm\|visual\|svg\|chart\|infograf"; then
    zone="diagram"
fi

# Content/copy zone
if echo "$user_input" | grep -qi "articol\|pagina\|copy\|content\|pubblica\|scri"; then
    zone="content"
fi

# Research/lab zone
if echo "$user_input" | grep -qi "ricerca\|autoricerca\|lab\|esperiment\|tensione\|seme\|CEC"; then
    zone="research"
fi

# Infrastructure zone
if echo "$user_input" | grep -qi "deploy\|container\|webhook\|nginx\|cron\|serviz"; then
    zone="infra"
fi

# ─── ZONE-SPECIFIC TOOLS ─────────────────────────────────

if [ "$zone" = "diagram" ]; then
    output="$output\n[CEA-ZONE: Diagrammi]"
    output="$output\n  Studio simbolismo: ${DND_PROJECT_DIR}/research/tools/data/STUDIO_SIMBOLISMO_DND.md"
    output="$output\n  Diagrammi operatore (dipolo+coni): chiedere all'operatore"
    output="$output\n  Registry: components/diagrams/PageDiagramRegistry.tsx (13 diagrammi)"
    output="$output\n  UniversalDiagram: renderizza da spec JSON — non serve componente custom"
    output="$output\n  Processo: contenuto pagina → CEC → risultante → spec → renderer"
    output="$output\n  A11: il diagramma nasce con la pagina, non dopo"
fi

if [ "$zone" = "content" ]; then
    output="$output\n[CEA-ZONE: Contenuto]"
    output="$output\n  COPY_RULES: ${DND_PROJECT_DIR}/docs/core/COPY_RULES.md"
    output="$output\n  CLAUDE.md sito: ${DND_PROJECT_DIR}/site/CLAUDE.md (tono, struttura, anti-pattern)"
    output="$output\n  A11: POST /api/pages arricchisce automaticamente (concetti, rilevanza, leads_to)"
    output="$output\n  Campo vivo: GET /api/campo — sai cosa succede nel sistema"
    output="$output\n  KG search: GET /api/search?q=... — trova pagine correlate"
    output="$output\n  Livello omega: pattern, non istanza. Se invecchia in 3 mesi, livello sbagliato."
fi

if [ "$zone" = "research" ]; then
    output="$output\n[CEA-ZONE: Ricerca]"
    output="$output\n  Seme corrente: ${DND_PROJECT_DIR}/research/tools/data/seme.json"
    output="$output\n  Condensato: ${DND_PROJECT_DIR}/research/CONDENSATO.md (A1-A11, F1-F6, C1-C3)"
    output="$output\n  Strumenti: CEC (:3008), Domandatore, Controprove, Godel (:3004)"
    output="$output\n  Autoricerca: dnd_autoricerca.py — campo vivo, A11 combo"
    output="$output\n  Lab data: /data/lab_data.json — 14 domini, traiettoria, multi-scala"
    output="$output\n  Auto-publish: scripts/auto_publish.py — Lab → pagine con diagramma"
fi

if [ "$zone" = "infra" ]; then
    output="$output\n[CEA-ZONE: Infrastruttura]"
    output="$output\n  ARCHITECTURE: ${DND_PROJECT_DIR}/docs/ARCHITECTURE.md"
    output="$output\n  CAPABILITY_MANIFEST: ${DND_PROJECT_DIR}/docs/nodes/CAPABILITY_MANIFEST.json"
    output="$output\n  Deploy: ./deploy.sh hotdeploy <file> (syntax check + copy + restart)"
    output="$output\n  Site Guardian: scripts/site_guardian.py (auto-fix dopo deploy)"
    output="$output\n  Webhook: /opt/github-webhook/webhook.js"
    output="$output\n  pages.json: SEMPRE formato {pages:[], metadata:{}} — mai array puro"
fi

# ─── ALWAYS-ON CHECKS ─────────────────────────────────

# Territory staleness
if [ -f "$TERRITORY_CACHE" ]; then
    age=$(( $(date +%s) - $(stat -c %Y "$TERRITORY_CACHE" 2>/dev/null || echo 0) ))
    if [ "$age" -gt 1800 ]; then
        output="$output\n[CEA] Territory map stale (${age}s). Verify before asserting."
    fi
fi

# Unread Sinapsi
SINAPSI_CACHE="/tmp/tm3_sinapsi_unread"
if [ -f "$SINAPSI_CACHE" ]; then
    unread=$(cat "$SINAPSI_CACHE" 2>/dev/null)
    if [ "$unread" -gt 0 ] 2>/dev/null; then
        output="$output\n[CEA] $unread unread Sinapsi message(s)."
    fi
fi

# Dirty repos + remote ahead check (prevents push conflicts)
for repo in ${DND_PROJECT_DIR} ${DND_PROJECT_DIR}/site ${DND_PROJECT_DIR}/research; do
    name=$(basename "$repo")
    dirty=$(cd "$repo" && git status --short 2>/dev/null | wc -l)
    if [ "$dirty" -gt 5 ]; then
        output="$output\n[CEA] $name: $dirty uncommitted files."
    fi
    # Check if local is behind remote (cached — last fetch, no network call)
    behind=$(cd "$repo" && git rev-list --count HEAD..origin/main 2>/dev/null || echo "0")
    if [ "$behind" -gt 0 ] 2>/dev/null; then
        output="$output\n[CEA] ⚠ $name: $behind commit(s) dietro a origin — pull prima di push!"
    fi
done

# Core reminder (rotates — includes autological awareness)
reminders=(
    "Before acting: what is the right question? The meta-question often contains the answer."
    "After this block: go up a level. Check what you missed."
    "Are you building or using? If building more than reading, stop."
    "When you find a good move, check if there's a better one nearby."
    "Correction received? Translate it into an executable rule (when X → do Y)."
    "Same tool three times? Switch. You might be looping."
    "What's the resultant? One sentence. If you can't compress it, you're expanding."
    "Territory, not map. Have you verified what you're about to assert?"
    "After every modification: cascade. What else needs to change?"
    "Available skills: /auto-learn /cascata /cec /eval /autologica"
)
idx=$((count / 5 % ${#reminders[@]}))
output="$output\n[CEA] ${reminders[$idx]}"

# Output
if [ -n "$output" ]; then
    echo -e "$output"
fi

