#!/bin/bash
# ============================================================================
# CONTEXT AWARENESS — Real-Time Context Window Monitor
# ============================================================================
# Generated by d-nd-seed for node: {{NODE_ID}}
# PostToolUse hook. Reads context_bridge.json, warns at 70/85/95%.
# At 85%: triggers SEED REMINDER to save reasoning chains.
# ============================================================================

BRIDGE_FILE="{{PROJECT_DIR}}/.claude/hooks/context_bridge.json"

# Skip if bridge doesn't exist
if [ ! -f "$BRIDGE_FILE" ]; then exit 0; fi

# Skip if stale (>10 min — statusline not running)
if command -v stat &>/dev/null; then
    FILE_AGE=$(( $(date +%s) - $(stat -c %Y "$BRIDGE_FILE" 2>/dev/null || echo 0) ))
    if [ "$FILE_AGE" -gt 600 ]; then exit 0; fi
fi

# Read context percentage
if command -v node &>/dev/null; then
    CONTEXT_PCT=$(node -e "
try { console.log(JSON.parse(require('fs').readFileSync('$BRIDGE_FILE','utf8')).contextPercent||0); }
catch(e) { console.log(0); }" 2>/dev/null)
elif command -v python3 &>/dev/null; then
    CONTEXT_PCT=$(python3 -c "
import json
try: print(json.load(open('$BRIDGE_FILE')).get('contextPercent',0))
except: print(0)" 2>/dev/null)
else
    exit 0
fi

CONTEXT_PCT=${CONTEXT_PCT:-0}

# Track phase transitions
PHASE_FILE="/tmp/{{NODE_ID}}_context_phase"
LAST_PHASE=$(cat "$PHASE_FILE" 2>/dev/null || echo "EARLY")

if [ "$CONTEXT_PCT" -ge 95 ] 2>/dev/null; then
    echo "=== CONTEXT CRITICAL (${CONTEXT_PCT}%) ==="
    echo "STOP new work. Commit changes, save reasoning, prepare for compaction."
    echo "=== ACTION: /compact or finish current task only ==="
    echo "CRITICAL" > "$PHASE_FILE"
elif [ "$CONTEXT_PCT" -ge 85 ] 2>/dev/null; then
    echo "=== CONTEXT WRAP-UP (${CONTEXT_PCT}%) ==="
    echo "Finish current work. Save reasoning to active_reasoning.md NOW."
    echo "=== ACTION: Complete current task, then /compact ==="
    echo "WRAP_UP" > "$PHASE_FILE"
    # First time entering WRAP_UP: remind to save cognitive state
    if [ "$LAST_PHASE" != "WRAP_UP" ] && [ "$LAST_PHASE" != "CRITICAL" ]; then
        echo ""
        echo ">>> SEED REMINDER: Save session discoveries to active_reasoning.md."
        echo ">>> Git/structural state is captured automatically by pre_compact."
        echo ">>> Cognitive state (reasoning chains, discoveries) must be saved by you."
    fi
elif [ "$CONTEXT_PCT" -ge 70 ] 2>/dev/null; then
    echo "=== CONTEXT LATE PHASE (${CONTEXT_PCT}%) ==="
    echo "Late phase. Focus on completing in-progress work."
    echo "=== ==="
    echo "LATE" > "$PHASE_FILE"
else
    echo "EARLY" > "$PHASE_FILE"
fi

exit 0

